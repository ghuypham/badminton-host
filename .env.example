# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# ============================================
# Badminton Host — App Config
# ============================================
# Admin account seeded vào DB lúc boot nếu bảng admins rỗng.
ADMIN_USERNAME=admin
# BẮT BUỘC: app fail-fast nếu rỗng. Không enforce độ mạnh (host tự chịu).
ADMIN_PASSWORD=
# BẮT BUỘC: secret ký session cookie. Sinh bằng: openssl rand -hex 32
SESSION_SECRET=

# Tùy chọn (mặc định an toàn cho self-host HTTP trực tiếp)
HOST_PORT=3000
PORT=3000
DATABASE_PATH=./data/badminton.sqlite
BACKUPS_DIR=./data/backups
# Bật khi chạy sau reverse proxy HTTPS:
COOKIE_SECURE=0
TRUST_PROXY=0
# URL gốc tuyệt đối sinh bill link (vd https://badminton.example.com). Rỗng = origin hiện tại.
APP_BASE_URL=
MAX_BACKUPS=10

# ============================================
# Claude Code Notification Hooks (không liên quan app)
# ============================================

# ============================================
# Discord Notifications
# ============================================
# Get your webhook URL from Discord:
# Server Settings → Integrations → Webhooks → New Webhook
# Format: https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
DISCORD_WEBHOOK_URL=

# ============================================
# Telegram Notifications
# ============================================
# Get bot token from @BotFather in Telegram
# Send /newbot to @BotFather and follow the prompts
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=

# Get chat ID from Telegram
# For DM: Send message to bot, then visit:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# For groups: Add bot to group, send message, check same URL
# Format: 987654321 (positive) or -100123456789 (negative for groups)
TELEGRAM_CHAT_ID=
